<view class="content"><block wx:if="{{ismobile}}"><block><view><view class="login-card"><view class="logo_title fc-common">{{''+title+''}}</view><view class="login-head"></view><view class="login-input login-margin-b"><input type="number" placeholder="请输入手机号" data-event-opts="{{[['input',[['__set_model',['','username','$event',[]]]]]]}}" value="{{username}}" bindinput="__e"/></view><view class="login-input"><input type="number" password="{{true}}" placeholder="请输入密码(6-16位)" data-event-opts="{{[['input',[['__set_model',['','password','$event',[]]]]]]}}" value="{{password}}" bindinput="__e"/></view><view class="margin-top flex justify-center"><button class="cu-btn bg-purple shadow-blur round" style="{{'background:'+(color)+';'}}" loading="{{loading}}" data-event-opts="{{[['tap',[['login',['$event']]]]]}}" bindtap="__e">{{loading?"登录中...":"手机登录"}}</button></view><view class="flex justify-center"><view data-event-opts="{{[['tap',[['wechatLogin',['$event']]]]]}}" class="text-gray text-sm margin-top-xl" bindtap="__e">微信登录</view><view style="width:20px;"></view><view data-event-opts="{{[['tap',[['register',['$event']]]]]}}" class="text-gray text-sm margin-top-xl" bindtap="__e">注册新账户</view></view></view></view></block></block><block wx:else><block><view class="logView"><button class="logbt" open-type="getPhoneNumber" data-event-opts="{{[['getphonenumber',[['thirdLogin',['wechat','$event']]]],['tap',[['thirdLogin',['wechat']]]]]}}" catchgetphonenumber="__e" catchtap="__e"><view class="logo_title fc-common">{{''+title+''}}</view><view class="loginTitile"><text decode="true">请点击微信登录，获取用户头像、昵称，主要用于向用户提供具有辨识度的用户中心界面</text></view><view class="cu-btn bg-blue shadow-blur round" style="{{'background:'+(color)+';'}}"><text class="cuIcon-lightauto"></text>微信登录</view><complete-data vue-id="3d36e1e8-1" isShow="{{iscomplete}}" avatarSrc="{{avatarUrl}}" name="{{nickname}}" data-event-opts="{{[['^backHome',[['backHome']]]]}}" bind:backHome="__e" bind:__l="__l"></complete-data></button><view class="flex justify-center"><view data-event-opts="{{[['tap',[['changMobileLogin']]]]}}" class="text-gray text-sm margin-top-xl" bindtap="__e">手机登录</view></view></view></block></block></view>