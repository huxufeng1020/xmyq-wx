<view><view class="title"><view class="name padding">标题</view><view class="input padding-lr"><input type="text" placeholder="请输入建议标题" placeholder-style="color:#ccc" data-event-opts="{{[['input',[['__set_model',['','title','$event',[]]]]]]}}" value="{{title}}" bindinput="__e"/></view></view><view class="title"><view class="name padding">建议内容</view><view class="textarea padding-lr"><textarea name id placeholder="请输入建议内容" placeholder-style="color:#ccc" cols="30" rows="10" data-event-opts="{{[['input',[['__set_model',['','content','$event',[]]]]]]}}" value="{{content}}" bindinput="__e"></textarea></view></view><view data-event-opts="{{[['tap',[['suggestion',['$event']]]]]}}" class="btn margin-top padding" bindtap="__e"><button>提交</button></view></view>