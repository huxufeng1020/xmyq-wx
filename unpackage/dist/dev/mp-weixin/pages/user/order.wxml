<view><view class="header flex_layout justify-between padding-lr"><view data-event-opts="{{[['tap',[['clickMenu',[-1]]]]]}}" class="{{['item',tab==-1?'active':'']}}" bindtap="__e">全部</view><view data-event-opts="{{[['tap',[['clickMenu',[0]]]]]}}" class="{{['item',tab==0?'active':'']}}" bindtap="__e">待付款</view><view data-event-opts="{{[['tap',[['clickMenu',[1]]]]]}}" class="{{['item',tab==1?'active':'']}}" bindtap="__e">已付款</view><view data-event-opts="{{[['tap',[['clickMenu',[2]]]]]}}" class="{{['item',tab==2?'active':'']}}" bindtap="__e">已取消</view><view data-event-opts="{{[['tap',[['clickMenu',[3]]]]]}}" class="{{['item',tab==3?'active':'']}}" bindtap="__e">已退款</view></view><view class="list padding-lr"><block wx:if="{{$root.g0>0}}"><block><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['detail',['$0'],[[['list','',index,'id']]]]]]]}}" class="item padding margin-top" bindtap="__e"><view class="flex_layout"><view class="left"><image src="{{item.table.coverimage}}" mode="aspectFill"></image></view><view class="right padding-left"><view class="{{['status','color1',item.status==0?'color1':item.status==1?'color2':item.status==2?'color3':'color3']}}">{{''+(item.status==0?'待付款':item.status==1?'已付款':item.status==2?'已取消':'已退款')+''}}</view><view class="style">{{item.arrivetime}}</view><view class="style">{{item.table.position+" "+item.table.name}}</view><view class="style">{{"定金 ￥"+item.table.deposits}}</view></view></view><block wx:if="{{item.leftTimeStatus}}"><view class="operate_btn flex_layout justify-end">剩余支付时间：<uni-countdown vue-id="{{'5b111dba-1-'+index}}" show-day="{{false}}" show-hour="{{false}}" color="#333333" splitorColor="#333333" fontSize="{{24}}" minute="{{item.lefttime_m}}" second="{{item.lefttime_s}}" bind:__l="__l"></uni-countdown></view></block><view class="operate_btn flex_layout justify-end"><block wx:if="{{item.status==0}}"><button data-event-opts="{{[['tap',[['payment',['$0'],[[['list','',index,'id']]]]]]]}}" class="btn1" catchtap="__e">立即支付</button></block><block wx:if="{{item.status==0}}"><button data-event-opts="{{[['tap',[['orderOp',[index,'$0'],[[['list','',index,'id']]]]]]]}}" class="btn2" catchtap="__e">取消订单</button></block></view></view></block></block></block><block wx:else><block><block wx:if="{{complete}}"><view class="nodata">暂无数据~~</view></block></block></block></view></view>