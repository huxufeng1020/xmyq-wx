page {
  background: #f2f2f2;
}
.back {
  background: #c2b183;
  height: 250rpx;
  border-radius: 0 0 50px 50px;
}
.header {
  background: #b79f5f;
  border-radius: 10px;
  width: 690rpx;
  margin: -210rpx auto 0 auto;
}
.header .style {
  color: #fff;
  font-size: 30rpx;
  line-height: 1;
}
.header .bottom .text {
  color: #997e45;
  font-size: 24rpx;
}
.header .bottom .num {
  color: #fff;
  font-size: 40rpx;
}
.info {
  background: #fff;
  border-radius: 10px;
}
.info .item .name {
  color: #333;
  font-size: 30rpx;
}
.info .item .right {
  color: #333;
  font-size: 30rpx;
}
.info .item .right picker {
  width: 100%;
}
.info .item .right input {
  display: block;
  width: 400rpx;
  color: #333;
  font-size: 30rpx;
  text-align: right;
}
.info .item .right image {
  display: block;
  width: 30rpx;
  height: 30rpx;
  margin-left: 20rpx;
}
.info .item .top .icon {
  transition: all 0.5s;
}
.info .item .top .icon image {
  display: block;
  width: 30rpx;
  height: 30rpx;
  margin-left: 20rpx;
}
.info .item .top .down {
  -webkit-transform: rotate(90deg);
          transform: rotate(90deg);
  margin-top: -20rpx;
}
.info .item .textarea {
  transition: all 0.5s;
}
.info .item .textarea textarea {
  color: #333;
  font-size: 30rpx;
  display: block;
  width: 100%;
  line-height: 1.8;
}
.info .item .develop {
  height: 180rpx;
}
.info .item .develop textarea {
  height: 180rpx;
}
.info .item .develop1 {
  height: 400rpx;
}
.info .item .develop1 textarea {
  height: 180rpx;
}
.info .item .checkbox_label {
  width: 33.33%;
  display: inline-block;
}
.info .item .shrink {
  height: 0;
}
.info .item .shrink textarea {
  height: 0;
}
.point_out {
  background: #fff;
  border-radius: 10px;
}
.point_out .name {
  color: #b29a5c;
  font-size: 30rpx;
}
.point_out .text rich-text {
  color: #999;
  font-size: 30rpx;
  line-height: 1.8;
}
.next_step {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
}
.next_step button {
  display: block;
  width: 220rpx;
  height: 75rpx;
  line-height: 75rpx;
  background: #b29a5c;
  color: #fff;
  font-size: 30rpx;
  border-radius: 5px;
}
