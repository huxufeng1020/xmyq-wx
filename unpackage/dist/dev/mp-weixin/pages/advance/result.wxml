<view><view class="success-box u-flex-col u-row-center u-col-center"><image class="pay-img" src="{{payImg[payState]}}" mode></image><text class="notice">{{payText[payState]}}</text><view class="btn-box flex_layout justify-between"><button data-event-opts="{{[['tap',[['index',['$event']]]]]}}" class="u-reset-button base-btn" bindtap="__e">返回首页</button><block wx:if="{{payState==='fail'}}"><button data-event-opts="{{[['tap',[['onPay',['$event']]]]]}}" class="u-reset-button again-pay" bindtap="__e">重新支付</button></block><block wx:else><button data-event-opts="{{[['tap',[['user',['$event']]]]]}}" class="u-reset-button base-btn" bindtap="__e">个人中心</button></block></view></view></view>