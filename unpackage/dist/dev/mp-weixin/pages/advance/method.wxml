<view class="pay-method-wrap"><block wx:if="{{loadStatus}}"><view class="money-box"><uni-countdown vue-id="5b757d1f-1" show-day="{{false}}" show-hour="{{false}}" color="#333333" splitorColor="#333333" fontSize="{{30}}" minute="{{lefttime_m}}" second="{{lefttime_s}}" data-event-opts="{{[['^timeup',[['timeup']]]]}}" bind:timeup="__e" bind:__l="__l"></uni-countdown></view></block><block wx:if="{{$root.g0}}"><radio-group data-event-opts="{{[['change',[['radioChange',['$event']]]]]}}" class="pay-box" bindchange="__e"><block wx:if="{{$root.g1}}"><label class="flex_layout u-row-between pay-item"><radio value="wechat" checked="{{payType=='wechat'}}" color="#f0c785"></radio><view class="flex_layout right_info"><image class="pay-img" src="../../static/order_wx_pay.png" mode></image><text>微信支付</text></view></label></block><block wx:if="{{$root.g2}}"><label class="flex_layout u-row-between pay-item"><radio value="alipay" checked="{{payType=='alipay'}}" color="#f0c785"></radio><view class="flex_layout right_info"><image class="pay-img" src="../../static/order_ali_pay.png" mode></image><text>支付宝支付</text></view></label></block><block wx:if="{{$root.g3}}"><label class="flex_layout u-row-between pay-item"><radio value="iospay" checked="{{payType=='iospay'}}" color="#f0c785"></radio><view class="flex_layout right_info"><image class="pay-img" src="../../static/order_apple_pay.png" mode></image><text>ApplePay</text></view></label></block><block wx:if="{{$root.g4}}"><label class="flex_layout u-row-between pay-item"><radio value="wallet" checked="{{payType=='wallet'}}" color="#f0c785"></radio><view class="flex_layout right_info"><image class="pay-img" src="../../static/order_wallet_pay.png" mode></image><text>余额支付</text></view></label></block></radio-group></block><button data-event-opts="{{[['tap',[['confirmPay',['$event']]]]]}}" class="u-reset-button pay-btn" bindtap="__e">{{"确认支付 ￥"+(orderDetail&&orderDetail.table?orderDetail.table.deposits:'0.00')}}</button></view>