<view><view class="back"></view><block wx:if="{{obj}}"><view class="header padding-lg"><view class="style">{{obj.reservedate}}</view><view class="style margin-top">{{obj.position+" "+obj.name}}</view><view class="bottom margin-top flex_layout justify-between"><view class="style">{{obj.type+" "+obj.reservebegintime+"-"+obj.reserveendtime}}</view><view class="right flex align-end"><view class="text margin-right-sm">定金</view><view class="num">{{"￥"+obj.deposits}}</view></view></view></view></block><view class="padding"><view class="info padding-lr"><view class="item padding-tb solid-bottom flex_layout justify-between"><view class="name">姓名</view><view class="right flex_layout"><input type="text" placeholder="请输入您的姓名" data-event-opts="{{[['input',[['__set_model',['','name','$event',[]]]]]]}}" value="{{name}}" bindinput="__e"/></view></view><view class="item padding-tb solid-bottom flex_layout justify-between"><view class="name">性别</view><view class="right flex_layout"><radio-group data-event-opts="{{[['change',[['radioChange',['$event']]]]]}}" bindchange="__e"><view class="flex_layout"><label class="flex_layout margin-right-xl"><view><radio style="transform:scale(0.8);" value="1" checked="{{sexdata==1}}"></radio></view><view class="name margin-left-xs">男</view></label><label class="flex_layout"><view><radio style="transform:scale(0.8);" value="0" checked="{{sexdata==0}}"></radio></view><view class="name margin-left-xs">女</view></label></view></radio-group></view></view><view class="item padding-tb solid-bottom flex_layout justify-between"><view class="name">联系电话</view><view class="right flex_layout"><input type="number" placeholder="请输入您的手机号" data-event-opts="{{[['input',[['__set_model',['','mobile','$event',[]]]]]]}}" value="{{mobile}}" bindinput="__e"/></view></view><view class="item solid-bottom"><view class="right flex_layout"><picker range="{{adultNum}}" value="{{adultIndex}}" data-event-opts="{{[['change',[['adultChange',['$event']]]]]}}" bindchange="__e"><view class="flex_layout justify-between padding-tb"><view class="name">成人人数</view><view class="right flex_layout">{{adultNumnumber}}<image src="../../static/right.png"></image></view></view></picker></view></view><view class="item solid-bottom"><view class="right flex_layout"><picker range="{{childrenNum}}" value="{{childrenIndex}}" data-event-opts="{{[['change',[['childrenChange',['$event']]]]]}}" bindchange="__e"><view class="flex_layout justify-between padding-tb"><view class="name">儿童人数</view><view class="right flex_layout">{{childNum}}<image src="../../static/right.png"></image></view></view></picker></view></view><view class="item solid-bottom"><view class="right flex_layout"><picker range="{{timeList}}" value="{{timeIndex}}" data-event-opts="{{[['change',[['timeChange',['$event']]]]]}}" bindchange="__e"><view class="flex_layout justify-between padding-tb"><view class="name">到店时间</view><view class="right flex_layout">{{arrivetime}}<image src="../../static/right.png"></image></view></view></picker></view></view></view><view class="info padding-lr margin-top"><view class="item"><view data-event-opts="{{[['tap',[['develop',[1]]]]]}}" class="top padding-tb flex_layout justify-between solid-bottom" bindtap="__e"><view class="name">您有什么食物忌口吗？</view><view class="{{['icon',show1?'down':'']}}"><image src="../../static/right.png"></image></view></view><view class="{{['textarea',show1?'develop':'shrink']}}"><textarea placeholder="请输入" data-event-opts="{{[['input',[['__set_model',['','avoidfood','$event',[]]]]]]}}" value="{{avoidfood}}" bindinput="__e"></textarea></view></view><view class="item"><view data-event-opts="{{[['tap',[['develop',[2]]]]]}}" class="top padding-tb flex_layout justify-between solid-bottom" bindtap="__e"><view class="name">您需要什么特殊节日准备吗？</view><view class="{{['icon','flex_layout',show2?'down':'']}}"><image src="../../static/right.png"></image></view></view><view class="{{['textarea',show2?'develop1':'shrink']}}"><block wx:if="{{show2}}"><checkbox-group data-event-opts="{{[['change',[['specialChange',['$event']]]]]}}" bindchange="__e"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="index"><label class="checkbox_label padding-tb-xs"><checkbox style="transform:scale(0.7);" value="{{item.g0}}"></checkbox><text class="margin-left-xs">{{item.$orig}}</text></label></block></checkbox-group></block><textarea class="margin-top-sm" placeholder="请输入" data-event-opts="{{[['input',[['__set_model',['','specialdatemark','$event',[]]]]]]}}" value="{{specialdatemark}}" bindinput="__e"></textarea></view></view><view class="item"><view data-event-opts="{{[['tap',[['develop',[3]]]]]}}" class="top padding-tb flex_layout justify-between solid-bottom" bindtap="__e"><view class="name">如果还有其他需要我们关照之外请留言。</view><view class="{{['icon',show3?'down':'']}}"><image src="../../static/right.png"></image></view></view><view class="{{['textarea',show3?'develop':'shrink']}}"><textarea placeholder="请输入" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" bindinput="__e"></textarea></view></view></view><view class="point_out margin-top padding"><view class="name">{{title+"："}}</view><view class="text margin-top-sm"><rich-text nodes="{{content}}"></rich-text></view></view></view><view style="height:130rpx;"></view><view class="next_step padding-lr padding-tb-sm flex_layout justify-around"><button data-event-opts="{{[['tap',[['backBtn',['$event']]]]]}}" bindtap="__e">上一步</button><button data-event-opts="{{[['tap',[['reserveBegin',['$event']]]]]}}" bindtap="__e">下一步</button></view></view>