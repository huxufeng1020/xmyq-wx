<view><view class="swiper"><swiper indicator-dots="{{true}}" autoplay="{{true}}" interval="{{3000}}" duration="{{1000}}"><block wx:for="{{swiperList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><swiper-item data-event-opts="{{[['tap',[['goPage',['$0','$1','$2'],[[['swiperList','',index,'utype']],[['swiperList','',index,'url']],[['swiperList','',index,'article_id']]]]]]]}}" bindtap="__e"><view class="swiper-item"><image src="{{item.aimage}}" mode="aspectFill"></image></view></swiper-item></block></swiper></view><view class="hall padding"><view class="title">精彩活动</view><block wx:for="{{articles}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['detail',['$0'],[[['articles','',index,'id']]]]]]]}}" class="item" bindtap="__e"><view class="img"><image src="{{item.coverimage}}" mode="aspectFill"></image></view><view class="bottom padding-sm"><view class="name">{{item.title}}</view></view></view></block></view><view class="hall padding"><view class="title">餐厅位置</view><block wx:for="{{addressList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="address margin-top"><block wx:if="{{item.mapimage}}"><view class="image"><image src="{{item.mapimage}}" mode="aspectFill"></image></view></block><view class="flex_layout justify-between padding-sm"><view class="left"><view class="name">{{item.name}}</view><view class="add">{{item.address}}</view></view><view data-event-opts="{{[['tap',[['routeTab',['$0','$1','$2','$3'],[[['addressList','',index,'lat']],[['addressList','',index,'lng']],[['addressList','',index,'name']],[['addressList','',index,'address']]]]]]]}}" class="right flex_layout justify-center" bindtap="__e">路线<image src="../../static/right.png"></image></view></view></view></block></view></view>