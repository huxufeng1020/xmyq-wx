page {
  background-color: #f2f2f2;
}
.swiper swiper {
  width: 100%;
  height: 300rpx;
}
.swiper swiper .swiper-item image {
  display: block;
  width: 100%;
  height: 300rpx;
}
.hall .title {
  color: #333;
  font-size: 36rpx;
  font-weight: bolder;
}
.hall .item {
  margin-top: 30rpx;
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
}
.hall .item .img image {
  display: block;
  width: 100%;
  height: 260rpx;
}
.hall .item .bottom .name {
  color: #333;
  font-size: 28rpx;
}
.hall .item .bottom .tab {
  background: #e4d7c4;
  color: #b29a5c;
  width: 100rpx;
  height: 46rpx;
  font-size: 26rpx;
  border-radius: 5px;
}
.hall .item .bottom .btn button {
  width: 120rpx;
  height: 52rpx;
  line-height: 52rpx;
  background: #b29a5c;
  color: #fff;
  font-size: 28rpx;
  margin: 0;
  padding: 0;
  border-radius: 5px;
}
.hall .item:first-child {
  margin-top: 0;
}
.hall .active {
  border: 2px solid #b29a5c;
}
.hall .address {
  background: #fff;
  border-radius: 10px 10px 0 0;
  overflow: hidden;
}
.hall .address .image image {
  display: block;
  width: 100%;
  height: 300rpx;
}
.hall .address .left {
  width: 500rpx;
}
.hall .address .left .name {
  font-size: 30rpx;
  color: #333;
  font-weight: bolder;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.hall .address .left .add {
  font-size: 26rpx;
  color: #333;
  margin-top: 10rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.hall .address .right {
  padding-left: 10rpx;
  width: 100rpx;
  height: 36rpx;
  border-radius: 36rpx;
  border: 1px solid #999;
  color: #333;
  font-size: 20rpx;
}
.hall .address .right image {
  display: block;
  width: 26rpx;
  height: 26rpx;
}
